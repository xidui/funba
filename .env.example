# Copy this file to .env for local CLI/docker-compose use.
# Production launchd services read ~/Library/LaunchAgents/app.funba.*.plist.

# MySQL connection.
# Native local CLI:
NBA_DB_URL=mysql+pymysql://root@localhost/nba_data
# Docker Compose workers reaching host MySQL:
# NBA_DB_URL=mysql+pymysql://root@host.docker.internal/nba_data

# Redis broker. Use redis://redis:6379/0 inside docker-compose if the worker
# runs in a container; use localhost for native launchd/CLI.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# X/Twitter engagement discovery.
# Creates Paperclip-backed manual-review work items only; it does not auto-reply.
# X_BEARER_TOKEN=
# FUNBA_TWITTER_ACCOUNT_HANDLE=funba_app
# FUNBA_TWITTER_ENGAGEMENT_TARGET_HANDLES=espn_macmahon,ShamsCharania
# FUNBA_TWITTER_ENGAGEMENT_QUERY=
# FUNBA_TWITTER_ENGAGEMENT_MAX_RESULTS=25
# FUNBA_TWITTER_ENGAGEMENT_DAILY_LIMIT=5
# FUNBA_TWITTER_ENGAGEMENT_MIN_SCORE=8
# FUNBA_TWITTER_ENGAGEMENT_INCLUDE_MENTIONS=1
# FUNBA_TWITTER_ENGAGEMENT_PAPERCLIP=1

# --- Container overrides ---
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
# NBA_DB_URL=mysql+pymysql://user:pass@rds-host.us-east-1.rds.amazonaws.com/nba_data
