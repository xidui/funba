<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>app.funba.backup</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/yuewang/Documents/github/funba/db/backup_mysql.sh</string>
    </array>

    <!-- Run daily at 02:00 local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/yuewang/Documents/github/funba/logs/backup-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/yuewang/Documents/github/funba/logs/backup-stderr.log</string>

    <!-- Run missed jobs when machine wakes if schedule was skipped -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
